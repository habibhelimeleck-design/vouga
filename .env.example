# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# Sur Vercel : ajouter ces variables dans Settings → Environment Variables.

# Exposé au navigateur (préfixe NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# Serveur uniquement — ne jamais préfixer avec NEXT_PUBLIC_
# Ne jamais importer depuis un composant 'use client'
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder